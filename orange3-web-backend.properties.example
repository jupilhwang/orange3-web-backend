# Orange3 Web Backend Configuration
# Copy this file to orange3-web-backend.properties and modify as needed

# =============================================================================
# Database Configuration
# =============================================================================
# database.url=postgresql+asyncpg://user:pass@localhost:5432/orange3
# database.url=mysql+aiomysql://user:pass@localhost:3306/orange3

# =============================================================================
# Server Configuration
# =============================================================================
# server.host=0.0.0.0
# server.port=8000
# server.workers=4

# =============================================================================
# Path Configuration
# =============================================================================
# path.upload=/var/lib/orange3-web/uploads
# path.corpus=/var/lib/orange3-web/corpus
# path.datasets_cache=/var/lib/orange3-web/datasets_cache
# path.database=/var/lib/orange3-web

# =============================================================================
# Storage Configuration
# =============================================================================
# Supported types: sqlite (default), mysql, postgresql, oracle, filesystem, local
storage.type=sqlite
storage.max_db_file_size=52428800

# =============================================================================
# Logging Configuration
# =============================================================================
# log.level=INFO
# log.database_echo=false

# =============================================================================
# mDNS Service Discovery (IPv4 only)
# =============================================================================
# Backend advertises itself via mDNS for frontend discovery
# mdns.enabled=true
# mdns.service_name=orange3-backend
# mdns.instance_name=orange3-backend
# mdns.port=8000
# mdns.multicast_address=224.0.0.251
# mdns.udp_port=5353
